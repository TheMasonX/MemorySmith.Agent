{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http": "Warning",
      "Microsoft.Extensions.Http": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Agent": {
    "Enabled": true,
    "Logging": {
      "Default": "Debug",
      "Overrides": {
        "WebUI.Blazor.AgentBackgroundService": "Debug"
      }
    },
    "Minecraft": {
      "ServerHost": "localhost",
      "ServerPort": 49187,
      "BotUsername": "Leo",
      "AutoStartNode": true,
      "NodeScriptPath": "../MineflayerAdapter/index.js",
      "NodeStartTimeoutMs": 20000
    },
    "Chat": {
      "LlmEnabled": true,
      "LlmProvider": "deepseek",
      "LlmModel": "deepseek-chat",
      "LlmApiKey": null,
      "LlmTimeoutSeconds": 15,
      "CommandExecutionEnabled": true,
      "PlayerCooldownSeconds": 3,
      "GlobalPerMinuteMax": 20,
      "Logging": {
        "Enabled": true
      }
    },
    "Memory": {
      "BaseUrl": "http://127.0.0.1:6868",
      "ApiKey": null,
      "WorldKbUrl": null,
      "WorldApiKey": null,
      "WorldTimeoutSeconds": 30
    },
    "Build": {
      "MaxConcurrentPlaceBlock": 8
    },
    "Safety": {
      "AllowDestructiveCommands": false,
      "DeniedCommands": [
        "/op", "/deop", "/kill", "/ban", "/ban-ip", "/pardon", "/pardon-ip",
        "/stop", "/save-off", "/save-on", "/save-all",
        "/reload", "/publish",
        "/whitelist", "/debug", "/difficulty", "/gamerule",
        "/setworldspawn", "/setblock", "/fill", "/clone", "/summon",
        "/gamemode", "/defaultgamemode", "/seed",
        "/kick", "/list", "/me", "/tell", "/msg", "/w", "/teammsg", "/tm",
        "/datapack", "/forceload", "/locate", "/loot", "/particle",
        "/place", "/playsound", "/recipe", "/return", "/ride",
        "/schedule", "/scoreboard", "/setidletimeout", "/spawnpoint",
        "/spectate", "/spreadplayers", "/stopsound", "/tag", "/team",
        "/teammsg", "/teleport", "/tellraw", "/tickingarea", "/title",
        "/tm", "/trigger", "/w", "/warden_spawn_tracker", "/weather",
        "/worldborder", "/execute"
      ]
    }
  }
}